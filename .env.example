# -----------------------------------------------------------------------------
# Noor Insight: environment template
# Copy to `.env.local` for local development (never commit secrets).
# -----------------------------------------------------------------------------

# Public site URL (used for metadataBase / absolute OG URLs)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Prisma + Supabase Postgres: use the direct connection string for migrations
# (Project Settings → Database → "Connection string" → URI; prefer port 5432 over pooler for `prisma migrate`).
# When set, `/platform/*` sign-in checks `User` rows first (bcrypt `passwordHash`); evaluation emails below apply only if no directory user exists.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/postgres?schema=public

# Supabase (optional until API layer is connected)
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# NextAuth (optional until you turn sign-in back on). Without NEXTAUTH_SECRET the app
# still boots using a built-in prototype secret — set a real secret for production.
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-openssl-rand-base64-32

# Evaluation console: shared password for role-separated pilot accounts (see `EVALUATION_PLATFORM_USERS` in code). Replace with directory-backed auth in production.
PLATFORM_DEMO_PASSWORD=NoorDemo#2026

# Mapbox: optional; enables live basemap on `/platform/dashboard` loss map
# NEXT_PUBLIC_MAPBOX_TOKEN=
