# -----------------------------------------------------------------------------
# Noor Insight: environment template
# Copy to `.env.local` for local development (never commit secrets).
# -----------------------------------------------------------------------------

# Public site URL (used for metadataBase / absolute OG URLs).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Contact form forwarding. The /contact POST handler sends the submitted
# briefing request to this mailbox. When unset the route returns 503 with an
# honest "not configured" message instead of silently dropping the message.
CONTACT_FORWARD_EMAIL=mahmoudmobir@gmail.com

# Contact form transport credentials (SMTP). Required only when
# CONTACT_FORWARD_EMAIL is set in a deploy. Locally, leave blank — the
# handler logs the payload to stdout and returns 200 for development only.
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM="Noor Insight <hello@noorinsight.co>"
